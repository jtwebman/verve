import "./math.vv";

process Main {
	receive main() -> int {
		Stdio.println("=== Multi-file Import Test ===");

		// Use exported Math module from math.vv
		Stdio.println("3 + 4 = ", Math.add(3, 4));
		Stdio.println("6 * 7 = ", Math.multiply(6, 7));
		Stdio.println("10! = ", Math.factorial(10));

		Stdio.println("=== Done ===");
		return 0;
	}
}
